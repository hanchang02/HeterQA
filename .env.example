# Local-only configuration. Copy to .env if needed. Never commit real secrets.

HETERQA_OPENAI_API_KEY=
HETERQA_OPENAI_BASE_URL=
HETERQA_TEXT_MODEL=
HETERQA_VISION_MODEL=
HETERQA_TEXT_EMBEDDING_MODEL=
HETERQA_VISUAL_TEXT_EMBEDDING_MODEL=
HETERQA_RERANK_MODEL=

# Optional SQL/OceanBase connection values.
HETERQA_DB_HOST=
HETERQA_DB_PORT=
HETERQA_DB_USER=
HETERQA_DB_PASSWORD=
HETERQA_DB_NAME=

# Optional local Yelp Open Dataset paths. Users must obtain Yelp data separately.
HETERQA_YELP_BUSINESS_JSON=
HETERQA_YELP_REVIEW_JSON=
HETERQA_YELP_PHOTO_JSON=
HETERQA_YELP_PHOTO_DIR=

# Optional Yelp -> OceanBase ingest helper.
# Set to 1 only after reviewing Yelp Open Dataset terms.
HETERQA_ACCEPT_YELP_TERMS=0
HETERQA_INCLUDE_YELP_PHOTOS=0
HETERQA_RESET_YELP_TABLES=0
HETERQA_YELP_TABLES=business,review,user,checkin,tip,photo
HETERQA_INGEST_BATCH_SIZE=1000
HETERQA_INGEST_MAX_ROWS_PER_TABLE=
